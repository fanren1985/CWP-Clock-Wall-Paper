<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CWP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorPrimaryVariant">#1565C0</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#03DAC5</item>
        <item name="colorSecondaryVariant">#00BFA5</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- 全局圆角设置：按钮/卡片等组件使用6dp圆角 -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.CWP.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CWP.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CWP.Large</item>
    </style>

    <!-- 小圆角 (6dp)：chip、按钮等 -->
    <style name="ShapeAppearance.CWP.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6dp</item>
    </style>

    <!-- 中圆角 (6dp)：卡片等 -->
    <style name="ShapeAppearance.CWP.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6dp</item>
    </style>

    <!-- 大圆角 (6dp)：大组件 -->
    <style name="ShapeAppearance.CWP.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6dp</item>
    </style>

    <!-- 圆形按钮：单文字/字符用 -->
    <style name="Widget.CWP.Button.Circle" parent="Widget.MaterialComponents.Button">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- 药丸形按钮：多文字/字符用 -->
    <style name="Widget.CWP.Button.Pill" parent="Widget.MaterialComponents.Button">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
